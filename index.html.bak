<tr><td>Custom Translator min</td><td>10,000+ parallel sentences</td></tr></table>`},
];

// ==================== STATE ====================
const LS_PREFIX = EXAM_CONFIG.id + '_';
const LS = {
  get(k,d){ try{return JSON.parse(localStorage.getItem(LS_PREFIX+k))||d}catch{return d} },
  set(k,v){ localStorage.setItem(LS_PREFIX+k,JSON.stringify(v)) }
};

// ==================== NORMALIZE FLASHCARD IDs ====================
// Phase 4: Ensure IDs are sequential (1, 2, 3, ...) and migrate localStorage
(function(){
  const oldIdMap = {};
  FLASHCARDS.forEach((card, idx) => {
    const newId = idx + 1;
    if(card.id !== newId) oldIdMap[card.id] = newId;
    card.id = newId;
  });
  // Migrate starred/mastered keys if any IDs changed
  if(Object.keys(oldIdMap).length > 0 && !LS.get('_idsMigrated',false)){
    ['starred','mastered'].forEach(key => {
      const old = LS.get(key,{});
      const migrated = {};
      for(const [id, val] of Object.entries(old)){
        const nid = oldIdMap[Number(id)] || Number(id);
        migrated[nid] = val;
      }
      LS.set(key, migrated);
    });
    LS.set('_idsMigrated', true);
  }
})();

// ==================== NAV ====================
document.querySelectorAll('.nav button').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
    if(btn.dataset.tab==='progress') renderProgress();
  });
});

// ==================== FLASHCARDS ====================
let fcDeck=[], fcIndex=0, fcFlipped=false, fcFilter='all', fcCorrect=0, fcWrong=0;
let starred = LS.get('starred',{});
let mastered = LS.get('mastered',{});

function buildDeck(filter, onlyStarred){
  let cards = FLASHCARDS.filter(c=> filter==='all' || c.d===filter);
  if(onlyStarred) cards = cards.filter(c=>starred[c.id]);
  // Shuffle
  for(let i=cards.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1));[cards[i],cards[j]]=[cards[j],cards[i]]; }
  // Put starred/unmastered first
  cards.sort((a,b)=>{
    const aP=(starred[a.id]?0:1)+(mastered[a.id]?2:0);
    const bP=(starred[b.id]?0:1)+(mastered[b.id]?2:0);
    return aP-bP;
  });
  return cards;
}

function initFlashcards(){
  const filtersEl = document.getElementById('fc-filters');
  filtersEl.innerHTML = `<button class="active" onclick="setFcFilter('all')">All</button>`;
  DOMAINS.forEach(d=>{ filtersEl.innerHTML += `<button onclick="setFcFilter('${d.id}')">${d.name}</button>`; });
  startDeck();
}

function setFcFilter(f){
  fcFilter=f;
  document.querySelectorAll('#fc-filters button').forEach((b,i)=>{
    b.classList.toggle('active', f==='all'?i===0:b.textContent===DOMAINS.find(d=>d.id===f)?.name);
  });
  startDeck();
}

function startDeck(onlyStarred){
  fcDeck=buildDeck(fcFilter, onlyStarred);
  fcIndex=0; fcCorrect=0; fcWrong=0;
  document.getElementById('fc-done').style.display='none';
  if(fcDeck.length===0){
    document.getElementById('fc-card').style.display='none';
    document.getElementById('fc-actions').style.display='none';
    document.getElementById('fc-done').style.display='block';
    document.getElementById('fc-summary').textContent=onlyStarred?'No starred cards!':'No cards in this filter.';
    return;
  }
  document.getElementById('fc-card').style.display='';
  showCard();
}

function resetDeck(){ startDeck(); }
function reviewStarred(){ startDeck(true); }

function showCard(){
  if(fcIndex>=fcDeck.length){
    document.getElementById('fc-card').style.display='none';
    document.getElementById('fc-actions').style.display='none';
    document.getElementById('fc-done').style.display='block';
    const pct = fcDeck.length?Math.round(fcCorrect/fcDeck.length*100):0;
    document.getElementById('fc-summary').textContent=`${fcCorrect}/${fcDeck.length} correct (${pct}%) — ${Object.keys(starred).filter(k=>starred[k]).length} cards starred for review`;
    renderProgress();
    return;
  }
  const c = fcDeck[fcIndex];
  const dom = DOMAINS.find(d=>d.id===c.d);
  document.getElementById('fc-domain').textContent = `${dom.name} · Card ${fcIndex+1}/${fcDeck.length}` + (starred[c.id]?' ★':'');
  document.getElementById('fc-question').textContent = c.q;
  document.getElementById('fc-answer').textContent = c.a;
  const card = document.getElementById('fc-card');
  card.classList.remove('flipped');
  card.style.display='';
  document.getElementById('fc-actions').style.display='none';
  fcFlipped=false;
  // Progress
  const pct = Math.round(fcIndex/fcDeck.length*100);
  document.getElementById('fc-count').textContent=`${fcIndex+1}/${fcDeck.length}`;
  document.getElementById('fc-bar').style.width=pct+'%';
  document.getElementById('fc-pct').textContent=pct+'%';
}

function flipCard(){
  if(fcFlipped) return;
  fcFlipped=true;
  document.getElementById('fc-card').classList.add('flipped');
  document.getElementById('fc-actions').style.display='flex';
}

function markCard(correct){
  const c = fcDeck[fcIndex];
  if(correct){
    fcCorrect++;
    mastered[c.id]=true;
    if(starred[c.id]) { delete starred[c.id]; }
  } else {
    fcWrong++;
    starred[c.id]=true;
    delete mastered[c.id];
  }
  LS.set('starred',starred);
  LS.set('mastered',mastered);
  // Track session
  const today = new Date().toISOString().slice(0,10);
  const sessions = LS.get('sessions',{});
  if(!sessions[today]) sessions[today]={reviewed:0,correct:0};
  sessions[today].reviewed++;
  if(correct) sessions[today].correct++;
  LS.set('sessions',sessions);

  fcIndex++;
  showCard();
}

// ==================== QUIZ ====================
let quizQs=[], quizIdx=0, quizScore=0, quizAnswered=false, quizDomain='all', quizAnswers=[];

function initQuiz(){
  const el = document.getElementById('quiz-domain-filters');
  el.innerHTML = `<button class="active" onclick="setQuizDomain('all',this)">All Domains</button>`;
  DOMAINS.forEach(d=>{ el.innerHTML += `<button onclick="setQuizDomain('${d.id}',this)">${d.name}</button>`; });
}

function setQuizDomain(d,btn){
  quizDomain=d;
  document.querySelectorAll('#quiz-domain-filters button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function startQuiz(n){
  let pool = QUIZ_QUESTIONS.filter(q=>quizDomain==='all'||q.d===quizDomain);
  for(let i=pool.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[pool[i],pool[j]]=[pool[j],pool[i]];}
  quizQs=pool.slice(0,Math.min(n,pool.length));
  quizIdx=0; quizScore=0; quizAnswers=[];
  document.getElementById('quiz-setup').style.display='none';
  document.getElementById('quiz-active').style.display='block';
  document.getElementById('quiz-results').style.display='none';
  showQuizQ();
}

function showQuizQ(){
  if(quizIdx>=quizQs.length){ showQuizResults(); return; }
  quizAnswered=false;
  const q=quizQs[quizIdx];
  const dom=DOMAINS.find(d=>d.id===q.d);
  document.getElementById('quiz-domain').textContent=dom.name;
  document.getElementById('quiz-question').textContent=`Q${quizIdx+1}. ${q.q}`;
  document.getElementById('quiz-explanation').style.display='none';
  document.getElementById('quiz-next').style.display='none';
  const optsEl=document.getElementById('quiz-opts');
  optsEl.innerHTML='';
  q.opts.forEach((o,i)=>{
    optsEl.innerHTML+=`<label id="qopt${i}" onclick="answerQuiz(${i})"><input type="radio" name="quiz">${String.fromCharCode(65+i)}) ${o}</label>`;
  });
  const pct=Math.round(quizIdx/quizQs.length*100);
  document.getElementById('quiz-count').textContent=`${quizIdx+1}/${quizQs.length}`;
  document.getElementById('quiz-bar').style.width=pct+'%';
  document.getElementById('quiz-score-live').textContent=`${quizScore} correct`;
}

function answerQuiz(i){
  if(quizAnswered) return;
  quizAnswered=true;
  quizAnswers[quizIdx]=i;
  const q=quizQs[quizIdx];
  const correct=i===q.ans;
  if(correct) quizScore++;
  document.getElementById(`qopt${i}`).classList.add(correct?'correct':'wrong');
  if(!correct) document.getElementById(`qopt${q.ans}`).classList.add('correct');
  const expEl=document.getElementById('quiz-explanation');
  expEl.textContent=(correct?'✓ Correct! ':'✗ Wrong. ')+q.exp;
  expEl.style.display='block';
  document.getElementById('quiz-next').style.display='';
  document.getElementById('quiz-score-live').textContent=`${quizScore} correct`;
}

function nextQuizQ(){ quizIdx++; showQuizQ(); }

function showQuizResults(){
  document.getElementById('quiz-active').style.display='none';
  document.getElementById('quiz-results').style.display='block';
  const pct=Math.round(quizScore/quizQs.length*100);
  document.getElementById('quiz-final-score').textContent=`${quizScore} / ${quizQs.length}`;
  document.getElementById('quiz-final-pct').textContent=`${pct}%`;
  const msgEl=document.getElementById('quiz-pass-msg');
  if(pct>=70) msgEl.innerHTML=`<span style="color:var(--green);font-size:1.2rem;font-weight:700">✓ Pass (≥70%)</span>`;
  else msgEl.innerHTML=`<span style="color:var(--red);font-size:1.2rem;font-weight:700">✗ Below passing — review starred flashcards</span>`;
  // Build review of wrong answers
  const reviewEl=document.getElementById('quiz-review');
  const wrongQs = quizQs.filter((_,i)=>quizAnswers[i]!==undefined && quizAnswers[i]!==quizQs[i].ans);
  if(wrongQs.length>0){
    let html=`<div class="card mt-20"><h3 style="margin-bottom:16px;color:var(--red)">✗ Review Wrong Answers (${wrongQs.length})</h3>`;
    wrongQs.forEach(q=>{
      const dom=DOMAINS.find(d=>d.id===q.d);
      html+=`<div style="margin-bottom:16px;padding:12px;background:var(--surface2);border-radius:var(--radius)">
        <div class="fc-domain">${dom.name}</div>
        <div style="font-size:.95rem;margin-bottom:8px">${q.q}</div>
        <div style="font-size:.85rem;color:var(--green)">✓ ${q.opts[q.ans]}</div>
        <div style="font-size:.85rem;color:var(--text2);margin-top:4px">${q.exp}</div>
      </div>`;
    });
    html+=`</div>`;
    reviewEl.innerHTML=html;
  } else {
    reviewEl.innerHTML=`<div class="card mt-20 text-center" style="color:var(--green)"><b>Perfect score! 🎉</b></div>`;
  }
  // Save
  const today=new Date().toISOString().slice(0,10);
  const quizHist=LS.get('quizHistory',[]);
  quizHist.push({date:today,score:quizScore,total:quizQs.length,pct});
  LS.set('quizHistory',quizHist);
}

function resetQuiz(){
  document.getElementById('quiz-setup').style.display='block';
  document.getElementById('quiz-active').style.display='none';
  document.getElementById('quiz-results').style.display='none';
}

// ==================== PROGRESS ====================
function renderProgress(){
  const sessions=LS.get('sessions',{});
  const quizHist=LS.get('quizHistory',[]);
  const totalReviewed=Object.values(sessions).reduce((s,v)=>s+v.reviewed,0);
  const totalCorrect=Object.values(sessions).reduce((s,v)=>s+v.correct,0);
  const masteredCount=Object.keys(mastered).filter(k=>mastered[k]).length;
  const starredCount=Object.keys(starred).filter(k=>starred[k]).length;
  const streak=calcStreak(sessions);
  const lastQuiz=quizHist.length?quizHist[quizHist.length-1]:null;

  document.getElementById('stats-grid').innerHTML=`
    <div class="stat-card"><div class="num" style="color:var(--accent)">${masteredCount}</div><div class="lbl">Cards Mastered</div></div>
    <div class="stat-card"><div class="num" style="color:var(--orange)">${starredCount}</div><div class="lbl">★ Need Review</div></div>
    <div class="stat-card"><div class="num" style="color:var(--green)">${totalReviewed}</div><div class="lbl">Total Reviews</div></div>
    <div class="stat-card"><div class="num" style="color:${lastQuiz&&lastQuiz.pct>=70?'var(--green)':'var(--red)'}">${lastQuiz?lastQuiz.pct+'%':'—'}</div><div class="lbl">Last Quiz</div></div>`;

  // Domain bars
  const barsEl=document.getElementById('progress-bars');
  barsEl.innerHTML='';
  DOMAINS.forEach(d=>{
    const domCards=FLASHCARDS.filter(c=>c.d===d.id);
    const domMastered=domCards.filter(c=>mastered[c.id]).length;
    const pct=domCards.length?Math.round(domMastered/domCards.length*100):0;
    barsEl.innerHTML+=`<div class="progress-domain">
      <div class="label">${d.name}</div>
      <div class="bar"><div class="bar-fill" style="width:${pct}%;background:${d.color}">${pct>8?pct+'%':''}</div></div>
      <span style="font-size:.8rem;color:var(--text3);width:50px;text-align:right">${domMastered}/${domCards.length}</span>
    </div>`;
  });

  document.getElementById('streak-info').innerHTML=`
    <div style="font-size:2rem;font-weight:800;color:var(--orange)">${streak} day${streak!==1?'s':''}</div>
    <div style="color:var(--text2);font-size:.85rem;margin-top:4px">${streak>0?'Keep it up!':'Study today to start your streak!'}</div>`;
}

function calcStreak(sessions){
  let streak=0, d=new Date();
  // Check if studied today
  const today=d.toISOString().slice(0,10);
  if(!sessions[today]){ d.setDate(d.getDate()-1); }
  while(true){
    const key=d.toISOString().slice(0,10);
    if(sessions[key]) { streak++; d.setDate(d.getDate()-1); }
    else break;
  }
  return streak;
}

function resetAllProgress(){
  if(!confirm('Reset all progress for ' + EXAM_CONFIG.code + '? This cannot be undone.')) return;
  // Only clear keys for THIS exam, not all localStorage
  const keysToRemove = [];
  for(let i=0; i<localStorage.length; i++){
    const key = localStorage.key(i);
    if(key && key.startsWith(LS_PREFIX)) keysToRemove.push(key);
  }
  keysToRemove.forEach(k => localStorage.removeItem(k));
  location.reload();
}

// ==================== CHEAT SHEETS ====================
function initCheatSheets(){
  const filtersEl=document.getElementById('cs-filters');
  filtersEl.innerHTML=`<button class="active" onclick="setCsFilter('all',this)">All</button>`;
  DOMAINS.forEach(d=>{filtersEl.innerHTML+=`<button onclick="setCsFilter('${d.id}',this)">${d.name}</button>`;});
  renderCheatSheets('all');
}

function setCsFilter(f,btn){
  document.querySelectorAll('#cs-filters button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderCheatSheets(f);
}

function renderCheatSheets(filter){
  const el=document.getElementById('cs-content');
  const items=CHEATSHEETS.filter(c=>filter==='all'||c.d===filter);
  el.innerHTML='';
  items.forEach((cs,i)=>{
    const dom=DOMAINS.find(d=>d.id===cs.d);
    el.innerHTML+=`<div class="cs-section" onclick="this.classList.toggle('open')">
      <div class="cs-header"><span><span class="tag tag-blue">${dom.name}</span> ${cs.title}</span><span class="arrow">▶</span></div>
      <div class="cs-body">${cs.content}</div>
    </div>`;
  });
}

// ==================== MIND MAPS ====================
const MINDMAPS = [
  {id:'d1', title:'Domain 1: Plan & Manage (20-25%)', color:'#3b82f6', md:`# Plan & Manage Azure AI
## Service Selection
### Azure OpenAI
- GPT-4o, GPT-4o-mini
- gpt-image-1 (images)
- Whisper (audio)
### Azure AI Vision
- Image Analysis 4.0
- Read API (OCR)
- Face API (limited access)
- Custom Vision (retiring 9/2028)
- Spatial Analysis (edge)
### Azure AI Language
- Text Analytics (sentiment, entities, PII)
- CLU (intents + entities)
- Custom Question Answering
### Azure AI Speech
- STT / TTS (neural voices)
- SSML
- Translation
- Intent + Keyword recognition
### Azure AI Search
- Indexers + Skillsets
- Semantic + Vector + Hybrid
### Document Intelligence
- Prebuilt (invoice, receipt, ID, W-2)
- Custom (template, neural)
- Composed models
### Others
- Translator (global endpoint!)
- Video Indexer
- Content Safety
- Microsoft Foundry
## Resource Types
### Multi-service
- Single key + endpoint
- Multiple services
- Can't get free tier
### Single-service
- Separate billing
- Free tier (F0)
- Standard tier (S0)
## Authentication
### Subscription Key
- Header: Ocp-Apim-Subscription-Key
- Dev/test only
### Entra ID (Azure AD)
- Header: Authorization: Bearer token
- RBAC-based (production)
### Managed Identity
- DefaultAzureCredential()
- No credentials in code
### Key Vault
- Secure key storage
- Key rotation pattern
- App uses Key1 → regen Key2 → switch → regen Key1
### RBAC Roles
- Cognitive Services User (call APIs)
- Cognitive Services Contributor (manage + call)
- CS OpenAI User (call OpenAI)
- CS OpenAI Contributor (manage + call OpenAI)
## Security
### Networking
- Private Endpoint (private IP in VNet)
- Service Endpoint (optimized route, public IP)
- Firewall rules (IP allowlist)
### Containers
- Docker from mcr.microsoft.com
- Phone-home for billing
- Disconnected = special approval
- Spatial Analysis = edge + NVIDIA GPU
## Responsible AI
### Content Filters
- Hate / Sexual / Violence / Self-harm
- Severity: safe → low → medium → high
- Applied to BOTH input AND output
### Additional Protections
- Blocklists (custom terms YOU define)
- Prompt shields (injection/jailbreak)
- Groundedness detection (context check)
- Protected material detection (copyright)
### 6 Principles
- Fairness
- Reliability & Safety
- Privacy & Security
- Inclusiveness
- Transparency
- Accountability
## Deployment Types
- Standard (pay-per-token)
- Global Standard (multi-region routing)
- Provisioned Throughput PTU (guaranteed tokens/min)
- Data Zone Standard (data residency)
## Monitoring
- Azure Monitor (metrics, logs, alerts)
- Diagnostic settings (Log Analytics, Storage, Event Hubs)
- Application Insights (tracing)
- Cost Management (budgets, alerts)
- Key metrics: Total Calls, Errors, Latency, 429s
## REST Endpoints
- Multi-service: <resource>.cognitiveservices.azure.com
- OpenAI: <resource>.openai.azure.com/openai/deployments/<dep>/...
- Search: <service>.search.windows.net
- Translator: api.cognitive.microsofttranslator.com (GLOBAL)
- Speech: <region>.api.cognitive.microsoft.com
- Translator needs Ocp-Apim-Subscription-Region header`},
  {id:'d2', title:'Domain 2: Generative AI (15-20%)', color:'#8b5cf6', md:`# Generative AI
## Models
### GPT-4o
- 128K in / 16K out
- Multimodal (text + images + audio)
### GPT-4o-mini
- 128K in / 16K out
- Replaces GPT-3.5 (fast + cheap)
### GPT-4 Turbo
- 128K in / 4K out
- Complex reasoning + vision
### gpt-image-1
- Image generation (replaces DALL-E)
- Sizes: 1024x1024, 1792x1024, 1024x1792
- Quality: standard or hd
### Whisper
- Audio transcription
- 25 MB file limit
### Embeddings
- text-embedding-3-large (3,072 dims)
- text-embedding-3-small (1,536 dims)
- text-embedding-ada-002 (1,536 dims, legacy)
- Max 2,048 items per batch
## API Parameters
### temperature (0.0-2.0)
- Low (0-0.3) = deterministic (code, data)
- High (0.7-1.5) = creative (marketing, stories)
### top_p (0.0-1.0)
- Nucleus sampling
- Don't set BOTH temperature AND top_p
### frequency_penalty (-2.0 to 2.0)
- Reduce word repetition
### presence_penalty (-2.0 to 2.0)
- Encourage new topics
### Others
- max_tokens (output length)
- stop (up to 4 sequences)
- n (number of completions)
- logprobs (token probabilities)
## Message Roles
- system (behavior/persona — first message)
- user (human input)
- assistant (AI response / few-shot examples)
- tool / function (tool call results)
## Prompt Engineering
### Techniques
- Zero-shot (no examples)
- One-shot / Few-shot (with examples)
- Chain-of-thought ("think step by step")
- Grounding (provide reference docs — RAG)
### Best Practices
- Use delimiters to separate instructions
- Specify output format (JSON, bullets)
- Provide examples of desired output
- System message for persistent rules
## RAG Pattern
### Flow
- User query → Azure AI Search retrieves docs
- Docs injected as context in system message
- Azure OpenAI generates grounded answer
### Key Components
- Embedding model (text → vectors)
- Azure AI Search (vector/semantic/hybrid)
- Azure OpenAI (generate answer)
### "On your data" Feature
- No-code RAG in Azure OpenAI Studio
- Connects to AI Search, Blob, uploaded files
- Auto-cites sources in response
## Microsoft Foundry
### Hub
- Top-level shared resource
- Compute, connections, policies
### Project
- Isolated workspace per team/use case
### Connections
- Links to OpenAI, AI Search, storage
### Prompt Flow
- Visual LLM orchestration
- Node types: LLM, Python, Prompt, Tool
### Evaluation Metrics
- Groundedness (supported by context?)
- Relevance (addresses the question?)
- Coherence (logically consistent?)
- Fluency (grammatically correct?)
- Similarity (close to ground truth?)
### Tracing
- Debug request pipeline end-to-end
## Fine-Tuning
- When prompt engineering isn't enough
- JSONL format: {"messages": [...]} per line
- Min 10 examples (50-100+ recommended)
- Models: GPT-4o, GPT-4o-mini, GPT-4.1 series
- Result = new custom deployment
- Cost = training + hosting
- Fine-tuning ≠ RAG
  - RAG = dynamic data grounding
  - Fine-tuning = style/format/domain behavior
## Deployment & Operations
### Types
- Standard (pay-per-token, shared)
- Global Standard (multi-region, highest availability)
- Provisioned PTU (reserved tokens/min)
- Data Zone (data stays in geography)
### Monitoring
- Azure Monitor + Application Insights
- Diagnostic settings → Log Analytics
- Content Safety dashboard
- Token usage metrics`},
  {id:'d3', title:'Domain 3: Agentic Solutions (5-10%)', color:'#06b6d4', md:`# Agentic Solutions
## What is an Agent?
- Receives a goal or task
- Plans steps to accomplish it
- Uses tools (APIs, functions, data)
- Iterates — observes results, adjusts
- Returns final answer or outcome
### Agent vs Chatbot
- Chatbot: responds to prompts, no tools, stateless
- Agent: plans autonomously, uses tools, maintains state
## Foundry Agent Service
### API Objects
- Agent (model + instructions + tools)
- Thread (conversation container)
- Message (user or assistant)
- Run (execution of agent on thread)
- RunStep (individual action: tool call, message)
### API Flow
- Create Agent → Create Thread → Add Messages
- Create Run → Poll Run status → Get results
### Built-in Tools
- Code Interpreter (Python sandbox)
- File Search (vector retrieval on uploads)
- Function Calling (your custom APIs)
- Azure AI Search (RAG)
- Bing Search (web grounding)
- Azure Functions (serverless code)
- Microsoft 365 (Graph API)
## Semantic Kernel
### Key Concepts
- Kernel (central orchestrator)
- Plugin (collection of callable functions)
- Function (single action: native or prompt)
- Planner (auto-creates execution plan)
- Memory (conversation history + facts)
- Connector (links to AI services)
### SDKs
- .NET, Python, Java
## Multi-Agent Patterns
- Sequential (chain: output → next input)
- Parallel (simultaneous subtasks)
- Hierarchical (manager → worker agents)
- Collaborative (agents discuss + refine)
### Key Considerations
- Handoff (transfer control between agents)
- Shared state (context/memory sharing)
- Conflict resolution (contradictions)
- Human-in-the-loop (approval at key points)
## Testing & Deployment
### Testing
- Unit test individual tools/functions
- End-to-end test with ground truth
- Test edge cases + adversarial inputs
### Optimization
- Refine system instructions
- Optimize tool descriptions (agent picks by description)
- Use smaller models for simple subtasks
### Deployment
- Microsoft Foundry portal or SDK
- Application Insights / tracing
- Content safety filters
- Rate limiting + authentication`},
  {id:'d4', title:'Domain 4: Computer Vision (10-15%)', color:'#f59e0b', md:`# Computer Vision
## Image Analysis 4.0
### Visual Features (API values)
- caption (single description + confidence)
- denseCaptions (multiple regions + bounding boxes)
- tags (content tags + confidence)
- objects (detected objects + bounding boxes)
- people (detected people + bounding boxes)
- smartCrops (crop regions, 0.75-1.8 ratio)
- read (OCR text + bounding polygons)
### Options
- language (en, ja, zh...)
- gender-neutral-caption (person/child instead of man/woman)
- model-version
### Region Availability
- caption + denseCaptions only in certain regions
## Service Selection
- Detect people (boxes): Image Analysis 4.0
- Identify WHO: Face API (Identify)
- "Cat or dog?": Custom Vision (classification)
- "Where are cats?": Custom Vision (object detection)
- Extract text: Read API or Document Intelligence
## Face API
### Detection Models
#### detection_01 (DEFAULT)
- General purpose
- Landmarks: YES
- Attributes: ALL (except mask)
#### detection_02
- Blurry / small / side-view faces
- Landmarks: NO
- Attributes: NO
#### detection_03 (BEST)
- Best accuracy overall
- Small faces (64x64), rotated
- Landmarks: YES
- Mask attribute: YES (only model!)
### Recognition Models
- recognition_01 (DEFAULT, legacy 2017)
- recognition_02 (improved 2019)
- recognition_03 (better 2020)
- recognition_04 (BEST 2021 + face masks)
### Critical Rules
- Can't change model after PersonGroup creation
- Models must be consistent within a group
- detection_02 = NO landmarks, NO attributes
- Default if unspecified: detection_01 + recognition_01
### Face Attributes
- blur (low/medium/high) — detection_01, _03
- exposure (under/good/over) — detection_01, _03
- glasses (No/Reading/Sun/Swimming) — detection_01, _03
- headPose (roll, yaw, pitch) — detection_01, _03
- mask (type + noseAndMouthCovered) — detection_03 ONLY
- noise (low/medium/high) — detection_01, _03
- occlusion (eye/forehead/mouth) — detection_01, _03
- qualityForRecognition — detection_01/_03 + recognition_03/_04
### Quality Rules
- High quality → enrollment
- Medium+ → identification
### Parameters
- detectionModel (01, 02, 03)
- recognitionModel (01-04)
- returnFaceId (true for recognition)
- returnFaceLandmarks (27 points)
- returnFaceAttributes (comma list)
- faceIdTimeToLive (default 86400s = 24h)
### Operations
- Detect (find faces, bounding boxes)
- Identify (match against PersonGroup, 1:many)
- Verify (same person? 1:1)
- Find Similar (FaceList)
- Group (cluster similar faces)
### PersonGroup Workflow
- Create group → Add persons → Add faces → Train → Identify
- PersonGroup/FaceList: immutable recognition model
- LargePersonGroup/LargeFaceList: >1000 items
### Limited Access
- Recognition requires approval (intake form)
- Detection is generally available
### Numbers
- Min face: 36x36 px
- Max face: 4096x4096 px
- Max image: 6 MB
- Formats: JPEG, PNG, GIF (1st frame), BMP
- Face ID TTL: 86400s (24h)
- Landmarks: 27 points
## Custom Vision
### Model Types
- Classification (what is it?) — min 5 img/tag (30+ rec)
- Multilabel (multiple tags per image)
- Object Detection (where is it?) — min 15 img/tag (50+ rec)
### Evaluation Metrics
- Precision (of predicted positives, how many correct)
- Recall (of actual positives, how many found)
- AP (area under PR curve)
- mAP (mean across classes)
### Workflow
- Create project → Upload + tag → Train → Evaluate → Publish → Consume
### Domains
- General (best accuracy, cloud)
- General Compact (export to ONNX/TF/CoreML)
- Food / Landmarks / Retail
### Compact Export
- ONNX, TensorFlow, CoreML
- For mobile / edge / IoT
### ⚠️ Retiring Sept 2028
- Migrate to Azure ML AutoML or Content Understanding
## Video Indexer
### Insights Extracted
- Faces, OCR, topics, keywords
- Sentiment, scenes, shots
- Transcript, translation
- Labels, brands, named entities
- Observed people (tracking)
### Access
- Portal: videoindexer.ai
- REST API
- Input: URL, upload, Azure Blob
## Spatial Analysis
### Operations
- Person counting (in a zone)
- Person distance (between people)
- Person zone crossing (enter/exit)
- Person line crossing (virtual line)
- Person dwell time (duration in zone)
### Requirements
- Edge device (Docker container)
- NVIDIA GPU required
- RTSP video stream input
- Use: retail, workplace safety, occupancy`},
  {id:'d5', title:'Domain 5: NLP & Speech (15-20%)', color:'#22c55e', md:`# NLP & Speech
## Text Analytics
### API Endpoints
- /text/analytics/v3.1/sentiment
- /text/analytics/v3.1/keyPhrases
- /text/analytics/v3.1/entities/recognition/general
- /text/analytics/v3.1/entities/recognition/pii
- /text/analytics/v3.1/languages
- /text/analytics/v3.1/entities/linking
### Features
- Sentiment (positive/negative/neutral/mixed)
- Key Phrases (strings, NO confidence scores)
- Named Entities (Person, Location, Org, DateTime...)
- PII Detection (redactedText with *****)
- Language Detection (no language field needed!)
- Entity Linking (links to Wikipedia)
### Limits
- Max 5,120 chars/doc
- Max 1,000 docs/request
- Max 1 MB/request
### Language Detection Gotcha
- No language field needed in request
- Returns "unknown" with confidence 1.0 (not 0.0!)
## Translator
### Unique Properties
- Global endpoint: api.cognitive.microsofttranslator.com
- Requires Ocp-Apim-Subscription-Region header
- NOT resource-specific endpoint
### Features
- Translate: to=fr&to=de&to=ja (multi-target)
- Source language: from=en (optional, auto-detect)
- Transliterate (script conversion, not translation)
- Detect (source language)
- Dictionary Lookup / Examples
- Document Translation (async batch: Word, PDF)
### Custom Translator
- Domain-specific parallel text
- 10,000+ sentence pairs for quality
- Publish → use category parameter in API
## Speech Service
### SDK Classes
- SpeechRecognizer (STT)
- SpeechSynthesizer (TTS)
- IntentRecognizer (speech + CLU intent)
- TranslationRecognizer (speech translation)
- KeywordRecognizer (wake word, .table file)
### Config Classes
- SpeechConfig (STT/TTS)
- SpeechTranslationConfig (translation)
- AudioConfig (file or microphone)
### Recognition Results
- result.reason: RecognizedSpeech / NoMatch / Canceled
- result.text: the recognized text
- result.offset / duration
### SSML Tags (EXAM FAVORITE)
- speak (root: version, xml:lang)
- voice (name="en-US-JennyNeural")
- prosody (rate/pitch/volume)
- break (time="500ms" or strength)
- emphasis (level: strong/moderate/reduced)
- say-as (interpret-as: date/telephone/cardinal/ordinal/spell-out)
- mstts:express-as (style: cheerful/sad/angry/excited)
- phoneme (alphabet: ipa/sapi, ph)
- sub (alias: "UN" → "United Nations")
- p / s (paragraph / sentence)
### SSML Namespace
- xmlns:mstts="http://www.w3.org/2001/mstts"
- Required for mstts:express-as tag!
### Prosody Values
- rate: x-slow/slow/medium/fast/x-fast/+50%
- pitch: x-low/low/medium/high/x-high/+10%
- volume: silent/x-soft/soft/medium/loud/x-loud
### Speech Translation
- Speech-to-text: add_target_language("fr")
- Speech-to-speech: also add voice_name
### Custom Speech
- Custom STT with your audio + transcripts
- For accents, domain terms, noisy environments
### Intent Recognition
- IntentRecognizer + CLU model
- Recognizes speech AND extracts intent + entities
### Keyword Recognition
- KeywordRecognizer + .table file
- Wake word detection (e.g., "Hey Computer")
- Generated via Speech Studio
## CLU (Conversational Language Understanding)
### Key Concepts
- Intent: what user wants (BookFlight)
- Entity: parameters (destination=Paris)
- Utterance: example sentence
- None intent: ALWAYS include (out-of-scope)
### Entity Types
- Learned (ML from labeled examples)
- List (fixed values + synonyms)
- Prebuilt (datetime, number, email, URL)
- Regex (pattern match: flight numbers)
### Workflow
- Create project → Define intents/entities
- Add utterances (5+ per intent)
- Train → Evaluate (precision/recall/F1)
- Deploy to named slot → Query via API
### CLU vs Custom Question Answering
- CLU: "Book a flight to Paris" → intent + entities
- QA: "How do I reset password?" → FAQ answer
- CLU = commands/actions
- QA = information retrieval
## Custom Question Answering
### Sources
- URL (FAQ pages)
- File (PDF, DOCX, XLSX, TXT, TSV)
- Manual (QnA pairs)
- Chit-chat (personality presets)
### Features
- Multi-turn (follow-up prompts)
- Alternate phrasing (multiple Qs → same A)
- Chit-chat: Professional/Friendly/Witty/Caring/Enthusiastic
- Active learning (suggests from traffic)
- Metadata (key-value filtering)
- Precise answering (short answer from passage)
- Multi-language
### Workflow
- Create → Add sources → Edit QnA → Add phrasing
- Multi-turn prompts → Chit-chat → Test → Deploy → Query
## Numbers to Remember
- Text Analytics: 5,120 chars/doc, 1,000 docs/req
- Custom Translator: 10,000+ parallel sentences
- SSML namespace: xmlns:mstts="http://www.w3.org/2001/mstts"
- Chit-chat: 5 personalities`},
  {id:'d6', title:'Domain 6: Knowledge Mining (15-20%)', color:'#ef4444', md:`# Knowledge Mining
## Azure AI Search
### Architecture
- Data Source → Indexer → [Skillset] → Index → Queries
- Knowledge Store (side output to storage)
### Data Sources
- Azure Blob / ADLS Gen2 (azureblob/adlsgen2)
- Azure SQL / Cosmos DB (azuresql/cosmosdb)
- Table Storage / MySQL (azuretable/mysql)
### Indexer
- fieldMappings (BEFORE enrichment: source → index)
- outputFieldMappings (AFTER enrichment: skillset → index)
- Schedule: ISO 8601 (PT2H = 2hrs, P1D = daily)
- Change detection (high watermark)
- Soft delete (flag column)
## Skillsets
### Built-in Skills (@odata.type)
- OCR: #Microsoft.Skills.Vision.OcrSkill
- Image Analysis: Vision.ImageAnalysisSkill
- Key Phrases: Text.KeyPhraseExtractionSkill
- Entity Recognition: Text.V3.EntityRecognitionSkill
- Entity Linking: Text.V3.EntityLinkingSkill
- Sentiment: Text.V3.SentimentSkill
- Language Detection: Text.LanguageDetectionSkill
- Translation: Text.TranslationSkill
- Text Split: Text.SplitSkill
- Text Merge: Text.MergeSkill
- Shaper: Util.ShaperSkill
- Document Extraction: Util.DocumentExtractionSkill
- PII Detection: Text.PIIDetectionSkill
- Custom Entity Lookup: Text.CustomEntityLookupSkill
- Conditional: Util.ConditionalSkill
### Custom Skills
- Azure Function (WebApiSkill)
- @odata.type: #Microsoft.Skills.Custom.WebApiSkill
- Request: values[].recordId + data
- Response: data + errors + warnings
- recordId in response MUST match request
- Timeout: 30s default, 230s max
### Context Paths
- /document (root)
- /document/content (text)
- /document/normalized_images/* (images)
- /document/pages/* (after text split)
## Index Schema
### Field Attributes
- searchable (free-text queries)
- filterable (exact match: $filter=rating ge 4)
- sortable (sort: $orderby=price)
- facetable (sidebar counts: \"Hotels (42)\")
- retrievable (show in results? set false to hide)
- stored (persisted on disk)
- key (unique doc ID — exactly one)
### Data Types
- Edm.String / Int32 / Int64
- Edm.Double / Boolean
- Edm.DateTimeOffset
- Edm.GeographyPoint
- Edm.ComplexType (nested)
- Collection(Edm.String)
- Collection(Edm.Single) = VECTOR field
## Query Syntax
### Simple (default)
- Space = OR
- "phrase" = exact match
- +term = must include (AND)
- -term = must exclude (NOT)
### Full Lucene (queryType=full)
- ~N fuzzy (edit distance)
- * ? wildcards
- field:value (field-scoped)
- /regex/ (regex)
- term^boost (boost a term)
### OData Filters
- eq, ne, gt, ge, lt, le
- and, or, not
- search.in() (value in list)
- geo.distance() (geographic)
- any() / all() (collection filters)
### Key Parameters
- $filter (exact match/comparison)
- $orderby (sort)
- $select (choose fields)
- $top / $skip (pagination)
- $count (include total)
- facets (category counts)
- highlight (hit highlighting)
- searchFields (limit search fields)
- scoringProfile (boost profile)
- queryType: simple (default) or full (Lucene)
- searchMode: any (OR default) or all (AND)
## Vector & Semantic Search
### Vector Search
- Store in Collection(Edm.Single) fields
- HNSW (fast approximate, default)
- Exhaustive KNN (slow exact, 100% recall)
- Metrics: cosine, euclidean, dotProduct, hamming
- HNSW params: m (4-10), efConstruction (100-1000), efSearch (100-1000)
### Semantic Search
- queryType=semantic&semanticConfiguration=name
- Provides semantic captions + answers
- Config: titleField, prioritizedContentFields, prioritizedKeywordsFields
### Hybrid Search
- Text + vector in single query
- Reciprocal Rank Fusion (RRF)
## Knowledge Store
### Projection Types
- Table → Azure Table Storage (analytics/Power BI)
- Object → Azure Blob Storage (JSON)
- File → Azure Blob Storage (images)
### Shaper Skill
- Reshape data structure for projections
## Scoring Profiles
### Functions
- magnitude (numeric value: rating, clicks)
- freshness (date recency)
- distance (geographic proximity)
- tag (matching tags from query param)
### Interpolation
- linear (default, steady decrease)
- constant (flat boost)
- quadratic (slow then sharp — NOT for tag)
- logarithmic (fast then slow — NOT for tag)
### Aggregation
- sum (default) / average / minimum / maximum / firstMatching
### Limits
- Max 100 scoring profiles per index
## Suggesters & Synonyms
### Suggesters
- Enable autocomplete + search suggestions
- searchMode: analyzingInfixMatching (only value)
- One suggester per index
- String fields only, default/language analyzer
- Adding to existing fields requires index rebuild
### Synonym Maps
- "hotel, motel, inn" (bidirectional)
- "US, United States => USA" (directional)
- One map per field
- Max 5,000 rules per map
## Document Intelligence
### Prebuilt Models
- prebuilt-invoice (vendor, dates, line items)
- prebuilt-receipt (merchant, items, total)
- prebuilt-idDocument (name, DOB, doc number)
- prebuilt-businessCard (name, company, phone)
- prebuilt-tax.us.w2 (employer, wages, tax)
- prebuilt-read (OCR text)
- prebuilt-layout (tables + structure)
- prebuilt-document (key-value pairs)
### Custom Models
- Template (fixed layout forms)
- Neural (variable layout forms)
- Min 5 labeled documents
### Composed Models
- Combine multiple custom models
- Auto-routes to correct sub-model
- Max 200 components
### API
- Async: POST returns Operation-Location → poll
### Content Understanding
- Broader than Doc Intelligence
- Summarize, classify, detect attributes
- Multi-modal: docs, images, video, audio
## Numbers to Remember
- AI Search free: 50 MB, 3 indexes
- AI Search Basic: 2 GB, 15 indexes
- Custom skill timeout: 30s default, 230s max
- Indexer max run (free): 3 min
- Indexer max run (standard): 2 hours
- Doc Intelligence min: 5 labeled docs
- Composed model max: 200 components
- Max scoring profiles: 100 per index
- Synonym maps: 5,000 rules max
- HNSW m: 4-10, efConstruction: 100-1000, efSearch: 100-1000`}
];

function initMindMaps(){
  const container = document.getElementById('mm-container');
  container.innerHTML = '';
  MINDMAPS.forEach((mm, idx) => {
    const section = document.createElement('div');
    section.className = 'mm-section';
    section.innerHTML = `
      <div class="mm-header" onclick="toggleMindMap(this, ${idx})">
        <span><span class="tag" style="background:${mm.color}22;color:${mm.color}">${mm.id.toUpperCase()}</span> ${mm.title}</span>
        <span class="arrow">▶</span>
      </div>
      <div class="mm-body">
        <div class="mm-wrap" id="mm-wrap-${idx}">
          <button class="mm-fullscreen-btn" onclick="toggleFullscreen(${idx})">⛶ Fullscreen</button>
          <div class="markmap" id="mm-${idx}">
            <script type="text/template">${mm.md}<\/script>
          </div>
        </div>
      </div>`;
    container.appendChild(section);
  });
}

function toggleMindMap(header, idx){
  const section = header.parentElement;
  const wasOpen = section.classList.contains('open');
  section.classList.toggle('open');
  if(!wasOpen && !section.dataset.rendered){
    section.dataset.rendered = '1';
    setTimeout(()=>{
      if(window.markmap && window.markmap.autoLoader){
        window.markmap.autoLoader.renderAll();
      }
    }, 100);
  }
}

function toggleFullscreen(idx){
  const wrap = document.getElementById('mm-wrap-' + idx);
  const btn = wrap.querySelector('.mm-fullscreen-btn');
  wrap.classList.toggle('mm-expanded');
  if(wrap.classList.contains('mm-expanded')){
    btn.textContent = '✕ Close';
    document.body.style.overflow = 'hidden';
  } else {
    btn.textContent = '⛶ Fullscreen';
    document.body.style.overflow = '';
  }
  // re-fit the SVG after resize
  setTimeout(()=>{
    if(window.markmap && window.markmap.autoLoader){
      window.markmap.autoLoader.renderAll();
    }
  }, 200);
}

// ==================== INIT ====================
initFlashcards();
initQuiz();
initCheatSheets();
initMindMaps();
renderProgress();
</script>
<script>
window.markmap = {
  autoLoader: { manual: true }
};
</script>
<script src="https://cdn.jsdelivr.net/npm/markmap-autoloader@latest"></script>
</body>
</html>
